# ═══════════════════════════════════════════════════════════════
# ECLIPSIS — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# ─── NEXT_PUBLIC_ PREFIX EXPLAINED ─────────────────────────
# Variables prefixed with NEXT_PUBLIC_ are inlined at BUILD TIME
# and sent to the browser. Use them ONLY for values that the
# client-side code needs (e.g., site URL for OG images, analytics).
#
# NEVER prefix secrets (API keys, CSRF_SECRET, Redis tokens) with
# NEXT_PUBLIC_ — they would be exposed in the browser bundle.
# ═══════════════════════════════════════════════════════════════

# ─── REQUIRED — site breaks without these ─────────────────────

# Resend API key for sending contact form emails
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Upstash Redis REST URL for rate limiting
# Get yours at: https://console.upstash.com/ → select your Redis database
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io

# Upstash Redis REST token (read-write)
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx

# Public site URL — used in sitemap, OG tags, canonical URLs
# MUST have NEXT_PUBLIC_ prefix (used client-side)
NEXT_PUBLIC_SITE_URL=https://eclipsis.agency

# HMAC secret for signing CSRF tokens — use a long random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=change_me_to_a_long_random_hex_string

# Email address that receives contact form submissions
CONTACT_EMAIL_TO=hello@eclipsis.agency

# ─── OPTIONAL BUT RECOMMENDED ────────────────────────────────

# Override the honeypot field name to evade bots that learn "honeypot"
# Do NOT add NEXT_PUBLIC_ prefix — this is server-side only
HONEYPOT_FIELD_NAME=honeypot

# Vercel deployment environment (auto-set by Vercel, useful for conditionals)
# NEXT_PUBLIC_VERCEL_ENV=production
